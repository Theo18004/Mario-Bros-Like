# --- Informations Générales ---
PROJECT_NAME           = "MarioBrosLike"
PROJECT_NUMBER         = 1.0
PROJECT_BRIEF          = "Moteur de jeu de plateforme 2D performant en C avec SDL2. Gère la physique, les collisions et le tilemapping."
OUTPUT_DIRECTORY       = doc 
OUTPUT_LANGUAGE        = French 
DOXYFILE_ENCODING      = UTF-8 

# --- Optimisation pour le Langage C ---
OPTIMIZE_OUTPUT_FOR_C  = YES 
EXTRACT_ALL            = YES 
EXTRACT_STATIC         = YES 
TYPEDEF_HIDES_STRUCT   = YES 
SHOW_FILES             = YES 

# --- Chemins d'entrée (Sources) ---
# Analyse le code source, les headers et le README pour la page d'accueil
INPUT                  = src lib README.md 
FILE_PATTERNS          = *.c *.h 
RECURSIVE              = YES 
USE_MDFILE_ASMAINPAGE  = README.md 
EXCLUDE                = bin test .git

# --- Configuration de l'Interface HTML ---
GENERATE_HTML          = YES 
HTML_OUTPUT            = html 
GENERATE_TREEVIEW      = YES 
DISABLE_INDEX          = NO 
HTML_COLORSTYLE        = AUTO_LIGHT 

# --- Recherche et Navigation ---
SEARCHENGINE           = YES 
SOURCE_BROWSER         = YES 

# --- Graphes et Diagrammes (Nécessite Graphviz/dot) ---
HAVE_DOT               = YES
CALL_GRAPH             = YES 
CALLER_GRAPH           = YES 
DIRECTORY_GRAPH        = YES 
DOT_IMAGE_FORMAT       = png 
GRAPHICAL_HIERARCHY    = YES 

# --- Désactivation des sorties inutiles ---
GENERATE_LATEX         = NO 
GENERATE_RTF           = NO 
GENERATE_XML           = NO 

# --- Images ---
IMAGE_PATH             = assets 